  "devDependencies": {
    "@types/bun": "latest",
    "prisma": "6",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@hono/node-server": "1.12.0",
    "@prisma/client": "6",
    "@vercel/node": "^5.1.0",
    "@vibecodeapp/backend-sdk": "^1.0.1",
    "@vibecodeapp/cloud-studio": "^0.2.4",
    "@vibecodeapp/proxy": "^2.0.3",
    "exceljs": "^4.4.0",
    "hono": "4.6.0",
    "resend": "^6.9.3",
    "xlsx": "^0.18.5",
    "zod": "4.1.11"
  }
